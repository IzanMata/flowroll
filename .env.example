# ─── Environment selector ─────────────────────────────────────────────────────
# Controls which settings module is loaded (development | production)
DJANGO_ENV=development

# ─── Django ───────────────────────────────────────────────────────────────────
# C-1 fix: generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string-in-production
# C-2 fix: must be False in production — production.py enforces this regardless
DEBUG=False
# Comma-separated list of allowed hostnames, e.g. "example.com,www.example.com"
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=flowroll
POSTGRES_USER=flowroll_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Seconds to keep a DB connection open between requests (0 = close after each)
DB_CONN_MAX_AGE=60

# ─── Redis ────────────────────────────────────────────────────────────────────
# L-6 fix: always include a password in production — redis://:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://:change-me@redis:6379/0

# ─── Gunicorn (optional overrides) ───────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_WORKER_CLASS=gthread
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_LOG_LEVEL=info

# ─── Celery (optional overrides) ─────────────────────────────────────────────
CELERY_CONCURRENCY=4
CELERY_LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to make cross-site requests
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Email (configure for production) ────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ─── Stripe Payment Processing ────────────────────────────────────────────────
# Get these from your Stripe dashboard (https://dashboard.stripe.com/apikeys)
# Use test keys for development (pk_test_... and sk_test_...)
# Use live keys for production (pk_live_... and sk_live_...)
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Webhook signing secret from Stripe dashboard webhooks section
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from Google Cloud Console (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
