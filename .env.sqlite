# ─── Configuración temporal para desarrollo con SQLite ─────────────────────────
# Para usar: cp .env.sqlite .env

# ─── Environment selector ─────────────────────────────────────────────────────
DJANGO_ENV=development

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-dev-only-do-not-use-in-production-ever
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Base de datos SQLite (sin PostgreSQL) ────────────────────────────────────
# Comentamos las variables de PostgreSQL para forzar el uso de SQLite
# POSTGRES_DB=flowroll
# POSTGRES_USER=flowroll_user
# POSTGRES_PASSWORD=password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# ─── Redis (opcional para desarrollo) ──────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ─── Celery ────────────────────────────────────────────────────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Email (desarrollo) ─────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ─── Static/Media ───────────────────────────────────────────────────────────────
STATIC_URL=/static/
MEDIA_URL=/media/